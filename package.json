{
  "name": "karasu",
  "version": "0.0.0",
  "private": true,
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "overrides": {
      "diff": "^8.0.3",
      "dompurify": "^3.3.2",
      "fast-uri": "^3.1.2",
      "serialize-javascript": "^7.0.5",
      "uuid": "^14.0.0"
    }
  },
  "scripts": {
    "dev": "pnpm --filter @karasu-tools/app run dev",
    "build": "pnpm --filter @karasu-tools/core run build && pnpm --filter @karasu-tools/lsp run build && pnpm --filter @karasu-tools/app run build && pnpm --filter ./packages/cli run build",
    "test": "pnpm --filter @karasu-tools/core run test && pnpm --filter @karasu-tools/app run test && pnpm --filter ./packages/cli run test && pnpm --filter @karasu-tools/lsp run test && pnpm --filter karasu-vscode run test && pnpm run test:scripts",
    "test:scripts": "vitest run --config scripts/vitest.config.ts",
    "test:coverage": "pnpm --filter @karasu-tools/core run test:coverage && pnpm --filter @karasu-tools/app run test:coverage && pnpm --filter ./packages/cli run test:coverage && pnpm run test:scripts",
    "lint": "oxlint --deny-warnings packages/ scripts/",
    "lint:fix": "oxlint --fix packages/ scripts/",
    "format": "oxfmt --write packages/ scripts/",
    "format:check": "oxfmt --check packages/ scripts/",
    "typecheck": "pnpm -r run typecheck && tsc --noEmit -p scripts/tsconfig.json",
    "knip": "knip",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "pnpm build && changeset publish",
    "check:cycles": "madge --circular --extensions ts,tsx packages/core/src packages/app/src packages/cli/src packages/lsp/src packages/vscode/src",
    "adr:init": "adr init",
    "adr:validate": "adr validate",
    "adr:extract": "adr extract",
    "adr:visualize": "adr visualize",
    "adr:regenerate": "adr regenerate",
    "adr:check-assumptions": "adr check-assumptions",
    "lint:e2e-page-goto": "tsx scripts/lint/no-direct-page-goto.ts",
    "tpl:validate": "tpl validate --config adr.config.json --packages-root packages",
    "tpl:related": "tpl related --config adr.config.json",
    "tpl:review:body": "tpl review-body --repo kompiro/karasu",
    "at:check-coverage": "tsx scripts/acceptance/check-coverage.ts",
    "at:test": "vitest run scripts/acceptance",
    "gen:reference": "tsx scripts/reference/gen-docs.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@kompiro/adr-tools": "^0.0.2",
    "@kompiro/tpl-tools": "^0.0.1",
    "@types/node": "^25.6.0",
    "knip": "^6.6.0",
    "lefthook": "^2.1.6",
    "madge": "^8.0.0",
    "oxfmt": "^0.46.0",
    "oxlint": "1.61.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
