{
  "name": "karasu",
  "version": "0.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "dompurify": "^3.3.2"
  },
  "scripts": {
    "dev": "npm run dev --workspace=packages/app",
    "build": "npm run build --workspace=packages/core && npm run build --workspace=packages/app",
    "test": "vitest run",
    "lint": "oxlint packages/",
    "lint:fix": "oxlint --fix packages/",
    "format": "oxfmt --write packages/",
    "format:check": "oxfmt --check packages/"
  },
  "devDependencies": {
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0"
  }
}
