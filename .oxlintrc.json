{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "import", "vitest"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "no-console": "warn",
    "react/react-in-jsx-scope": "off",
    "no-await-in-loop": "off",
    "import/no-unassigned-import": "off"
  },
  "overrides": [
    {
      "files": ["packages/vscode-e2e/tests/**/*.ts"],
      "rules": {
        "jest/expect-expect": [
          "error",
          { "assertFunctionNames": ["assert", "assert.*"] }
        ]
      }
    }
  ],
  "settings": {
    "react": {
      "version": "19"
    }
  },
  "ignorePatterns": ["dist", "out", "node_modules", "*.d.ts"]
}
