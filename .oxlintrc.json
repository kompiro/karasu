{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["react", "typescript", "import", "vitest"],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  },
  "rules": {
    "no-console": "warn",
    "react/react-in-jsx-scope": "off",
    "no-await-in-loop": "off",
    "import/no-unassigned-import": "off"
  },
  "overrides": [
    {
      "files": ["packages/vscode-e2e/tests/**/*.ts"],
      "rules": {
        "jest/expect-expect": [
          "error",
          { "assertFunctionNames": ["assert", "assert.*"] }
        ]
      }
    },
    {
      "files": ["packages/core/src/**/*.ts"],
      "rules": {
        "no-restricted-imports": [
          "error",
          {
            "patterns": [
              {
                "group": ["**/index.js", "**/index"],
                "message": "Do not import from core/index.ts inside core/. Use direct module paths to avoid barrel-induced cycles."
              }
            ]
          }
        ]
      }
    },
    {
      "files": ["packages/core/src/**/*.test.ts", "packages/core/src/**/*.spec.ts"],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
  "settings": {
    "react": {
      "version": "19"
    }
  },
  "ignorePatterns": ["dist", "out", "node_modules", "*.d.ts"]
}
