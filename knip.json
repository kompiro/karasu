{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    ".": {
      "entry": [],
      "project": []
    },
    "packages/core": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts", "!src/**/*.test.ts"]
    },
    "packages/app": {
      "project": ["src/**/*.{ts,tsx}", "!src/**/*.test.{ts,tsx}"]
    },
    "packages/lsp": {
      "entry": ["src/server.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/vscode": {
      "entry": ["src/extension.ts"],
      "project": ["src/**/*.ts"]
    },
    "packages/e2e": {
      "entry": ["tests/**/*.spec.ts"],
      "project": ["tests/**/*.ts"]
    }
  },
  "ignoreBinaries": ["vitest", "lefthook", "oxfmt", "oxlint", "knip", "vite", "tsc"],
  "ignoreDependencies": ["lefthook", "oxfmt", "oxlint"]
}
