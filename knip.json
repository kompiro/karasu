{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    ".": {
      "project": ["scripts/**/*.ts"]
    },
    "packages/core": {
      "project": ["src/**/*.ts", "!src/**/*.test.ts"]
    },
    "packages/i18n": {
      "project": ["src/**/*.ts", "!src/**/*.test.ts"]
    },
    "packages/app": {
      "project": ["src/**/*.{ts,tsx}", "!src/**/*.test.{ts,tsx}"]
    },
    "packages/lsp": {
      "project": ["src/**/*.ts"]
    },
    "packages/vscode": {
      "project": ["src/**/*.ts"]
    },
    "packages/e2e": {
      "entry": ["tests/**/*.spec.ts"],
      "project": ["tests/**/*.ts"]
    },
    "packages/vscode-e2e": {
      "entry": [".vscode-test.mjs", "tests/suite/**/*.test.ts"],
      "project": ["tests/**/*.ts"],
      "ignoreDependencies": ["@vscode/test-electron"]
    }
  }
}
