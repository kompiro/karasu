{
  "permissions": {
    "allow": [
      "Bash(git commit:*)",
      "Bash(rm /workspaces/karasu/*)",
      "Bash(rmdir /workspaces/karasu/*)",
      "Bash(git add:*)",
      "Bash(npm install:*)",
      "Bash(npm audit:*)",
      "Bash(npm show:*)",
      "Bash(npx vitest:*)",
      "Bash(npx tsc:*)",
      "Bash(npx vite:*)",
      "Bash(git:*)",
      "Bash(npm ls:*)",
      "Bash(find:*)",
      "Bash(npm run:*)",
      "Bash(grep:*)",
      "Bash(node -e \":*)",
      "WebSearch",
      "Bash(npm test:*)",
      "Bash(wc -l /workspaces/karasu/packages/core/src/**/*.ts /workspaces/karasu/packages/app/src/**/*.ts*)",
      "Bash(npx oxlint:*)",
      "Bash(npx oxfmt:*)",
      "Bash(ls /workspaces/karasu/.claude/skills/*/)",
      "Bash(gh:*)",
      "Bash(npm ci:*)",
      "Bash(cd /workspaces/karasu* && git:*)"
    ],
    "additionalDirectories": [
      "/workspaces",
      "/workspaces/karasu",
      "/workspaces/karasu/.claude",
      "/workspaces/karasu/.worktrees"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "pkill -f '[v]ite' 2>/dev/null || true",
            "if": "Bash(git worktree remove:*)",
            "statusMessage": "Stopping dev server..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "CWD=$(cat | jq -r '.cwd'); if cd \"$CWD\" 2>/dev/null && git status --short | grep -qE '^[ MADRCU?][MADRCU?]|^[MADRCU][MADRCU ]'; then echo '{\"decision\": \"block\", \"reason\": \"Uncommitted changes detected. Run /commit to commit changes.\"}'; else echo '{}'; fi"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(cat | jq -r '.tool_input.file_path'); if [[ \"$FILE\" == *.ts || \"$FILE\" == *.tsx ]]; then cd /workspaces/karasu && npx oxfmt --write \"$FILE\" 2>&1 && npx oxlint \"$FILE\" 2>&1; fi"
          }
        ]
      }
    ]
  },
  "enabledPlugins": {
    "commit-commands@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "hane@kompiro-hane": true
  },
  "defaultMode": "acceptEdits"
}
