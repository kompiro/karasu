{
  "name": "@karasu-tools/lsp",
  "version": "0.1.0",
  "private": true,
  "description": "Language Server for .krs architecture files",
  "main": "./out/server.js",
  "scripts": {
    "build": "esbuild src/server.ts --bundle --platform=node --format=cjs --outfile=out/server.js --external:vscode-languageserver --external:vscode-languageserver-textdocument",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@karasu-tools/core": "workspace:*",
    "vscode-languageserver": "^9.0.1",
    "vscode-languageserver-textdocument": "^1.0.12"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  }
}
