{
  "name": "karasu-vscode",
  "displayName": "karasu",
  "version": "0.1.1",
  "private": true,
  "description": "Syntax highlighting and tooling for .krs architecture files",
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "keywords": [
    "C4",
    "architecture",
    "architecture diagram",
    "diagram",
    "karasu",
    "krs",
    "modeling"
  ],
  "homepage": "https://github.com/kompiro/karasu#readme",
  "bugs": {
    "url": "https://github.com/kompiro/karasu/issues"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kompiro/karasu.git",
    "directory": "packages/vscode"
  },
  "qna": "marketplace",
  "publisher": "karasu-tools",
  "main": "./out/extension.js",
  "scripts": {
    "prebuild": "tsx ../../scripts/ci/generate-third-party-notices.ts .",
    "build": "pnpm --filter @karasu-tools/lsp run build && esbuild src/extension.ts --bundle --platform=node --format=cjs --outfile=out/extension.js --external:vscode && node -e \"require('node:fs').cpSync('../lsp/out/server.js', 'out/server.js')\"",
    "postbuild": "node scripts/assert-server-bundled.mjs",
    "package": "pnpm run build && vsce package --no-dependencies",
    "publish": "pnpm run build && vsce publish --no-dependencies",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@karasu-tools/core": "workspace:*",
    "marked": "^18.0.2",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.111.0",
    "@vscode/vsce": "^3.6.2",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "contributes": {
    "commands": [
      {
        "command": "karasu.openPreview",
        "title": "karasu: Open Preview",
        "icon": {
          "light": "./images/karasu-light.svg",
          "dark": "./images/karasu-dark.svg"
        }
      },
      {
        "command": "karasu.tidyStyle",
        "title": "karasu: Tidy Style"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "karasu.openPreview",
          "when": "resourceLangId == krs",
          "group": "navigation"
        }
      ]
    },
    "languages": [
      {
        "id": "krs",
        "aliases": [
          "karasu",
          "krs"
        ],
        "extensions": [
          ".krs"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "krs-style",
        "aliases": [
          "karasu style",
          "krs-style"
        ],
        "extensions": [
          ".krs.style"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "krs",
        "scopeName": "source.krs",
        "path": "./syntaxes/krs.tmLanguage.json"
      },
      {
        "language": "krs-style",
        "scopeName": "source.krs-style",
        "path": "./syntaxes/krs-style.tmLanguage.json"
      }
    ]
  },
  "activationEvents": [
    "onLanguage:krs",
    "onLanguage:krs-style"
  ],
  "icon": "icon.png",
  "galleryBanner": {
    "color": "#1F2430",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.111.0"
  }
}
