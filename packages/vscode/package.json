{
  "name": "karasu-vscode",
  "displayName": "karasu",
  "version": "0.1.0",
  "private": true,
  "description": "Syntax highlighting and tooling for .krs architecture files",
  "categories": [
    "Programming Languages"
  ],
  "publisher": "karasu",
  "main": "./out/extension.js",
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --platform=node --format=cjs --outfile=out/extension.js --external:vscode",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@karasu-tools/core": "workspace:*",
    "marked": "^17.0.6",
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.2"
  },
  "contributes": {
    "commands": [
      {
        "command": "karasu.openPreview",
        "title": "karasu: Open Preview"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "karasu.openPreview",
          "when": "resourceLangId == krs",
          "group": "navigation"
        }
      ]
    },
    "languages": [
      {
        "id": "krs",
        "aliases": [
          "karasu",
          "krs"
        ],
        "extensions": [
          ".krs"
        ],
        "configuration": "./language-configuration.json"
      },
      {
        "id": "krs-style",
        "aliases": [
          "karasu style",
          "krs-style"
        ],
        "extensions": [
          ".krs.style"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "krs",
        "scopeName": "source.krs",
        "path": "./syntaxes/krs.tmLanguage.json"
      },
      {
        "language": "krs-style",
        "scopeName": "source.krs-style",
        "path": "./syntaxes/krs-style.tmLanguage.json"
      }
    ]
  },
  "activationEvents": [],
  "engines": {
    "vscode": "^1.85.0"
  }
}
