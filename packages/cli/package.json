{
  "name": "karasu",
  "version": "0.2.0",
  "description": "karasu CLI — serve and build .krs architecture diagrams",
  "homepage": "https://github.com/kompiro/karasu#readme",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kompiro/karasu.git",
    "directory": "packages/cli"
  },
  "bin": {
    "karasu": "./dist/index.js"
  },
  "files": [
    "dist/index.js",
    "THIRD_PARTY_NOTICES.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prebuild": "tsx ../../scripts/ci/generate-third-party-notices.ts .",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/index.js --alias:@karasu-tools/core=../core/src/index.ts --alias:@karasu-tools/i18n=../i18n/src/index.ts --external:commander --external:chokidar --external:yaml",
    "prepack": "pnpm run build",
    "dev": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/index.js --alias:@karasu-tools/core=../core/src/index.ts --alias:@karasu-tools/i18n=../i18n/src/index.ts --external:commander --external:chokidar --external:yaml --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "commander": "^14.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@karasu-tools/core": "workspace:*",
    "@karasu-tools/i18n": "workspace:*",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "esbuild": "^0.28.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20"
  }
}
