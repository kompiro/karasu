{
  "name": "@karasu-tools/docs-site",
  "version": "0.0.0",
  "private": true,
  "description": "karasu documentation site (Astro Starlight) built from docs/",
  "type": "module",
  "scripts": {
    "sync": "tsx scripts/sync.ts",
    "check-links": "tsx scripts/check-links.ts",
    "dev": "pnpm run sync && astro dev",
    "build": "pnpm run sync && pnpm run check-links && astro build",
    "preview": "astro preview",
    "test": "vitest run",
    "test:coverage": "vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.scripts.json"
  },
  "devDependencies": {
    "@astrojs/starlight": "^0.40.0",
    "astro": "^6.4.7",
    "github-slugger": "^2.0.0",
    "tsx": "^4.22.4",
    "vitest": "^4.1.4"
  }
}
