        },
        {
          key: "2026-06",
          accent: "#34d399",
          commits: 179,
          adr: 41,
          tpl: 24,
          types: { docs: 77, feat: 38, fix: 22, chore: 20, refactor: 16, test: 6 },
        },
      ];
      const WEEKS_NUM = [
        { w: "W11", range: "03/13–03/14", commits: 11, adr: 4, tpl: 0 },
        { w: "W12", range: "03/17–03/22", commits: 32, adr: 6, tpl: 0 },
        { w: "W13", range: "03/23–03/29", commits: 67, adr: 17, tpl: 0 },
        { w: "W14", range: "03/30–04/05", commits: 111, adr: 32, tpl: 0 },
        { w: "W15", range: "04/06–04/12", commits: 131, adr: 31, tpl: 0 },
        { w: "W16", range: "04/13–04/19", commits: 109, adr: 10, tpl: 0 },
