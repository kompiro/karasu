        { w: "W19", range: "05/04–05/10", commits: 86, adr: 19, tpl: 23 },
        { w: "W20", range: "05/11–05/16", commits: 98, adr: 17, tpl: 11 },
        { w: "W21", range: "05/18–05/22", commits: 62, adr: 14, tpl: 6 },
        { w: "HIATUS", range: "05/23–06/09", commits: 0, adr: 0, tpl: 0 },
        { w: "W24", range: "06/10–06/14", commits: 34, adr: 5, tpl: 7 },
