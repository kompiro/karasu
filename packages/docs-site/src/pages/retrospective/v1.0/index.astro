            "Snapshot as of 2026-06-25 · auto-extracted from git history, docs/adr, and docs/test-perspectives",
          stats: [
            { c: "c-commit", num: "1,127", lbl: "total commits" },
            { c: "c-adr", num: "237", lbl: "ADRs (design decisions)" },
            { c: "c-tpl", num: "64", lbl: "TPLs (test perspectives)" },
            { c: "c-month", num: "4", lbl: "months (Mar–Jun)" },
