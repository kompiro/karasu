      const SVGNS = "http://www.w3.org/2000/svg";
      const el = (n, a = {}) => {
        const e = document.createElementNS(SVGNS, n);
        for (const k in a) e.setAttribute(k, a[k]);
        return e;
      };

      function renderWeeklyChart() {
        const host = document.getElementById("weeklyChart");
        host.innerHTML = "";
        const wk = WEEKS_NUM.filter((w) => w.w !== "HIATUS");
        const W = 1000,
          H = 320,
          mL = 44,
          mR = 44,
          mB = 56,
          mT = 16,
          iw = W - mL - mR,
          ih = H - mT - mB;
        const maxC = Math.max(...wk.map((w) => w.commits)),
          maxLine = Math.max(...wk.map((w) => Math.max(w.adr, w.tpl)));
        const svg = el("svg", { viewBox: `0 0 ${W} ${H}` });
        const n = wk.length,
          slot = iw / n;
        const x = (i) => mL + slot * i + slot / 2,
          yC = (v) => mT + ih - (v / maxC) * ih,
          yL = (v) => mT + ih - (v / maxLine) * ih;
        for (let g = 0; g <= 4; g++) {
          const yy = mT + ih * (g / 4);
          const v = Math.round(maxC * (1 - g / 4));
          svg.appendChild(el("line", { x1: mL, y1: yy, x2: W - mR, y2: yy, stroke: "#2a2f3a" }));
          const t = el("text", {
            x: mL - 8,
            y: yy + 4,
            fill: "#98a2b3",
            "font-size": 11,
            "text-anchor": "end",
          });
          t.textContent = v;
          svg.appendChild(t);
        }
        const bw = slot * 0.5;
        wk.forEach((w, i) => {
          const h = (w.commits / maxC) * ih;
          svg.appendChild(
            el("rect", {
              x: x(i) - bw / 2,
              y: yC(w.commits),
              width: bw,
              height: h,
              rx: 3,
              fill: "#4f9cf9",
              "fill-opacity": 0.78,
            }),
          );
          const t = el("text", {
            x: x(i),
            y: yC(w.commits) - 6,
            fill: "#cdd5e0",
            "font-size": 10.5,
            "text-anchor": "middle",
          });
          t.textContent = w.commits;
          svg.appendChild(t);
          const lab = el("text", {
            x: x(i),
            y: H - mB + 18,
            fill: "#98a2b3",
            "font-size": 11,
            "text-anchor": "middle",
          });
          lab.textContent = w.w;
          svg.appendChild(lab);
          const lab2 = el("text", {
            x: x(i),
            y: H - mB + 33,
            fill: "#5b6472",
            "font-size": 9.5,
            "text-anchor": "middle",
          });
          lab2.textContent = w.range;
          svg.appendChild(lab2);
        });
        function poly(key, color) {
          const pts = wk.map((w, i) => `${x(i)},${yL(w[key])}`).join(" ");
          svg.appendChild(
            el("polyline", {
              points: pts,
              fill: "none",
              stroke: color,
              "stroke-width": 2.5,
              "stroke-linejoin": "round",
              "stroke-linecap": "round",
            }),
          );
          wk.forEach((w, i) => {
            svg.appendChild(el("circle", { cx: x(i), cy: yL(w[key]), r: 3.5, fill: color }));
            if (w[key] > 0) {
              const t = el("text", {
                x: x(i),
                y: yL(w[key]) - 9,
                fill: color,
                "font-size": 10,
                "text-anchor": "middle",
                "font-weight": 700,
              });
              t.textContent = w[key];
              svg.appendChild(t);
            }
          });
        }
        poly("adr", "#c9a227");
        poly("tpl", "#ec5fa0");
        host.appendChild(svg);
      }
      function renderCumChart() {
        const host = document.getElementById("cumChart");
        host.innerHTML = "";
        const wk = WEEKS_NUM.filter((w) => w.w !== "HIATUS");
        let ca = 0,
          ct = 0;
        const pts = wk.map((w) => {
          ca += w.adr;
          ct += w.tpl;
          return { w: w.w, adr: ca, tpl: ct };
        });
        const W = 1000,
          H = 300,
          mL = 44,
          mR = 20,
          mB = 50,
          mT = 16,
          iw = W - mL - mR,
          ih = H - mT - mB;
        const maxV = Math.max(...pts.map((p) => p.adr));
        const svg = el("svg", { viewBox: `0 0 ${W} ${H}` });
        const n = pts.length,
          x = (i) => mL + (iw / (n - 1)) * i,
          y = (v) => mT + ih - (v / maxV) * ih;
        for (let g = 0; g <= 4; g++) {
          const yy = mT + ih * (g / 4);
          const v = Math.round(maxV * (1 - g / 4));
          svg.appendChild(el("line", { x1: mL, y1: yy, x2: W - mR, y2: yy, stroke: "#2a2f3a" }));
          const t = el("text", {
            x: mL - 8,
            y: yy + 4,
            fill: "#98a2b3",
            "font-size": 11,
            "text-anchor": "end",
          });
          t.textContent = v;
          svg.appendChild(t);
        }
        const areaPts = pts.map((p, i) => `${x(i)},${y(p.adr)}`).join(" ");
        svg.appendChild(
          el("polygon", {
            points: `${mL},${y(0)} ${areaPts} ${x(n - 1)},${y(0)}`,
            fill: "#c9a227",
            "fill-opacity": 0.1,
          }),
        );
        function line(key, color) {
          const pp = pts.map((p, i) => `${x(i)},${y(p[key])}`).join(" ");
          svg.appendChild(
            el("polyline", {
              points: pp,
              fill: "none",
              stroke: color,
              "stroke-width": 3,
              "stroke-linejoin": "round",
            }),
          );
          pts.forEach((p, i) =>
            svg.appendChild(el("circle", { cx: x(i), cy: y(p[key]), r: 3, fill: color })),
          );
          const last = pts[n - 1];
          const t = el("text", {
            x: x(n - 1) - 4,
            y: y(last[key]) - 10,
            fill: color,
            "font-size": 13,
            "font-weight": 800,
            "text-anchor": "end",
          });
          t.textContent = last[key];
          svg.appendChild(t);
        }
        line("adr", "#c9a227");
        line("tpl", "#ec5fa0");
        pts.forEach((p, i) => {
          const lab = el("text", {
            x: x(i),
            y: H - mB + 20,
            fill: "#98a2b3",
            "font-size": 10.5,
            "text-anchor": "middle",
          });
          lab.textContent = p.w;
          svg.appendChild(lab);
        });
        host.appendChild(svg);
      }
      function renderMonths(L) {
        document.getElementById("months").innerHTML = MONTHS_NUM.map((m, idx) => {
          const c = L.months[idx];
          const total = Object.values(m.types).reduce((a, b) => a + b, 0);
          const order = Object.entries(m.types).sort((a, b) => b[1] - a[1]);
          const bar = order
            .map(
              ([k, v]) =>
                `<span style="width:${((v / total) * 100).toFixed(2)}%;background:${TYPE_COLORS[k] || "#888"}" title="${k}: ${v}"></span>`,
            )
            .join("");
          const labels = order
            .map(
              ([k, v]) =>
                `<span><i style="background:${TYPE_COLORS[k] || "#888"}"></i>${k} ${v}</span>`,
            )
            .join("");
          const hls = c.highlights.map((h) => `<li>${h}</li>`).join("");
          return `<div class="month" style="--accent:${m.accent}">
      <div class="mh"><span class="mname" style="color:${m.accent}">${c.name}</span><span class="mst">${c.subtitle}</span></div>
      <div class="mini"><div><b style="color:var(--feat)">${m.commits}</b> commits</div><div><b style="color:var(--adr)">${m.adr}</b> ADR</div><div><b style="color:var(--tpl)">${m.tpl}</b> TPL</div></div>
      <p class="narrative">${c.narrative}</p>
      <div class="typebar">${bar}</div>
      <div class="typelabels">${labels}</div>
      <details><summary>${L.monthDetails(c.highlights.length)}</summary><ul class="hl">${hls}</ul></details>
    </div>`;
        }).join("");
      }
      function renderWeekTable(L) {
        const maxC = Math.max(...WEEKS_NUM.map((w) => w.commits));
        document.querySelector("#weekTable tbody").innerHTML = WEEKS_NUM.map((w) => {
          if (w.w === "HIATUS")
            return `<tr class="hiatus-row"><td colspan="8">${L.hiatusRow}</td></tr>`;
          const bw = ((w.commits / maxC) * 100).toFixed(1);
          return `<tr><td class="wk">${w.w}</td><td class="rng">${w.range}</td>
      <td><span class="badge-m">${L.weekMonth[w.w]}</span></td>
      <td class="num-cell">${w.commits}</td>
      <td class="bartd"><span class="minibar" style="width:${bw}%"></span></td>
      <td class="num-cell" style="color:var(--adr)">${w.adr}</td>
      <td class="num-cell" style="color:var(--tpl)">${w.tpl || "–"}</td>
      <td class="note">${L.weekNotes[w.w]}</td></tr>`;
        }).join("");
      }
      function applyText(L) {
        document.querySelectorAll("[data-i]").forEach((node) => {
          const key = node.getAttribute("data-i");
          if (typeof L[key] === "string") node.innerHTML = L[key];
        });
      }
      function setLang(lang) {
        const L = I18N[lang] || I18N.en;
        document.documentElement.lang = L.htmlLang;
        document.title = L.title;
        try {
          localStorage.setItem("karasu-retro-lang", lang);
        } catch (e) {}
        // toggle buttons
        document
          .querySelectorAll(".langtoggle button")
          .forEach((b) => b.classList.toggle("active", b.dataset.lang === lang));
        // dynamic header bits
        document.getElementById("d0").textContent = META.firstCommit;
        document.getElementById("d1").textContent = META.lastCommit;
        document.getElementById("dweeks").textContent = L.period("14");
        // stats
        document.getElementById("stats").innerHTML = L.stats
          .map(
            (s) =>
              `<div class="stat ${s.c}"><div class="num">${s.num}</div><div class="lbl">${s.lbl}</div></div>`,
          )
          .join("");
        applyText(L);
        renderMonths(L);
        renderWeekTable(L);
        // charts are language-independent but redraw to be safe
        renderWeeklyChart();
        renderCumChart();
      }
      (function init() {
        const params = new URLSearchParams(location.search);
        let lang = params.get("lang");
        if (lang !== "en" && lang !== "ja") {
          try {
            lang = localStorage.getItem("karasu-retro-lang");
          } catch (e) {}
        }
        if (lang !== "en" && lang !== "ja") {
          lang = "en";
        }
        setLang(lang);
      })();
    </script>
  </body>
</html>
