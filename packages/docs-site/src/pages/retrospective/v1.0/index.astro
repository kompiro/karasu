<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>karasu 1.0 — Development Retrospective</title>
    <meta
      name="description"
      content="A retrospective of karasu's road to its 1.0 language spec — monthly and weekly summaries tracking commits, ADRs, and TPLs (snapshot as of 2026-06-25)."
    />
    <style is:global>
      :root {
        --bg: #0f1115;
        --bg-card: #181b22;
        --bg-card2: #1f232c;
        --ink: #e6e9ef;
        --ink-dim: #98a2b3;
        --line: #2a2f3a;
        --crow: #c9a227;
        --feat: #4f9cf9;
        --docs: #9b8cff;
        --fix: #f97362;
        --chore: #6b7280;
        --refactor: #34d399;
        --test: #f0b429;
        --ci: #14b8a6;
        --adr: #c9a227;
        --tpl: #ec5fa0;
      }
      * {
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        margin: 0;
        background: var(--bg);
        color: var(--ink);
        font-family:
          -apple-system, BlinkMacSystemFont, "Segoe UI", "Hiragino Sans", "Noto Sans JP", sans-serif;
        line-height: 1.7;
        font-size: 15px;
      }
      a {
        color: var(--feat);
        text-decoration: none;
      }
      .wrap {
        max-width: 1080px;
        margin: 0 auto;
        padding: 0 24px 96px;
      }

      /* lang toggle + back link */
      .topbar {
        position: sticky;
        top: 0;
        z-index: 50;
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 10px 18px;
        background: rgba(15, 17, 21, 0.86);
        backdrop-filter: blur(8px);
        border-bottom: 1px solid var(--line);
      }
      .topbar .back {
        color: var(--ink-dim);
        font-size: 13px;
      }
      .topbar .back:hover {
        color: var(--ink);
      }
      .langtoggle {
        display: inline-flex;
        border: 1px solid var(--line);
        border-radius: 20px;
        overflow: hidden;
      }
      .langtoggle button {
        background: transparent;
        color: var(--ink-dim);
        border: 0;
        padding: 5px 14px;
        font-size: 12.5px;
        cursor: pointer;
        font-weight: 600;
      }
      .langtoggle button.active {
        background: var(--crow);
        color: #1a1a1a;
      }

      header.hero {
        text-align: center;
        padding: 64px 24px 52px;
        background: radial-gradient(
          900px 400px at 50% -10%,
          rgba(201, 162, 39, 0.16),
          transparent 70%
        );
        border-bottom: 1px solid var(--line);
      }
      .crow-mark {
        font-size: 56px;
        line-height: 1;
        filter: drop-shadow(0 4px 12px rgba(201, 162, 39, 0.4));
      }
      header.hero h1 {
        font-size: 40px;
        margin: 14px 0 6px;
        letter-spacing: -0.02em;
      }
      header.hero .jp {
        color: var(--crow);
        font-weight: 700;
      }
      header.hero .sub {
        color: var(--ink-dim);
        font-size: 17px;
        margin: 0;
      }
      header.hero .period {
        margin-top: 18px;
        font-variant-numeric: tabular-nums;
        color: var(--ink-dim);
        font-size: 14px;
      }
      header.hero .period b {
        color: var(--ink);
      }
      .snapshot {
        display: inline-block;
        margin-top: 14px;
        font-size: 12px;
        color: var(--ink-dim);
        border: 1px solid var(--line);
        border-radius: 20px;
        padding: 3px 12px;
      }

      .stats {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 14px;
        margin: 40px 0 8px;
      }
      .stat {
        background: var(--bg-card);
        border: 1px solid var(--line);
        border-radius: 14px;
        padding: 18px 14px;
        text-align: center;
      }
      .stat .num {
        font-size: 30px;
        font-weight: 800;
        letter-spacing: -0.02em;
      }
      .stat .lbl {
        color: var(--ink-dim);
        font-size: 12.5px;
        margin-top: 4px;
      }
      .stat.c-commit .num {
        color: var(--feat);
      }
      .stat.c-adr .num {
        color: var(--adr);
      }
      .stat.c-tpl .num {
        color: var(--tpl);
      }
      .stat.c-spec .num {
        color: var(--refactor);
      }
      .stat.c-month .num {
        color: var(--docs);
      }

      h2.section {
        font-size: 24px;
        margin: 64px 0 8px;
        padding-bottom: 10px;
        border-bottom: 1px solid var(--line);
      }
      .section-note {
        color: var(--ink-dim);
        margin: 0 0 24px;
        font-size: 14px;
      }

      .card {
        background: var(--bg-card);
        border: 1px solid var(--line);
        border-radius: 16px;
        padding: 24px;
        margin: 18px 0;
      }
      .card h3 {
        margin: 0 0 4px;
        font-size: 16px;
      }
      .card .hint {
        color: var(--ink-dim);
        font-size: 13px;
        margin: 0 0 18px;
      }
      svg {
        display: block;
        width: 100%;
        height: auto;
        overflow: visible;
      }
      .legend {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-top: 16px;
        font-size: 12.5px;
        color: var(--ink-dim);
      }
      .legend span {
        display: inline-flex;
        align-items: center;
        gap: 6px;
      }
      .legend i {
        width: 11px;
        height: 11px;
        border-radius: 3px;
        display: inline-block;
      }

      .month {
        background: var(--bg-card);
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 28px;
        margin: 22px 0;
        position: relative;
        overflow: hidden;
      }
      .month::before {
        content: "";
        position: absolute;
        left: 0;
        top: 0;
        bottom: 0;
        width: 5px;
        background: var(--accent, var(--crow));
      }
      .month .mh {
        display: flex;
        align-items: baseline;
        gap: 14px;
        flex-wrap: wrap;
      }
      .month .mh .mname {
        font-size: 26px;
        font-weight: 800;
      }
      .month .mh .mst {
        color: var(--ink-dim);
        font-size: 15px;
      }
      .month .mini {
        display: flex;
        gap: 22px;
        margin: 16px 0 18px;
        flex-wrap: wrap;
      }
      .month .mini div {
        font-variant-numeric: tabular-nums;
        font-size: 14px;
      }
      .month .mini b {
        font-size: 19px;
      }
      .month .narrative {
        color: var(--ink);
        font-size: 14.5px;
        margin: 0 0 18px;
      }
      .month .narrative strong {
        color: var(--crow);
        font-weight: 700;
      }
      .month .typebar {
        display: flex;
        height: 26px;
        border-radius: 7px;
        overflow: hidden;
        margin-bottom: 8px;
      }
      .month .typebar span {
        display: block;
      }
      .month .typelabels {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
        font-size: 12px;
        color: var(--ink-dim);
        margin-bottom: 18px;
      }
      .month .typelabels i {
        width: 9px;
        height: 9px;
        border-radius: 2px;
        display: inline-block;
        margin-right: 5px;
      }
      .month details {
        border-top: 1px solid var(--line);
        padding-top: 14px;
      }
      .month summary {
        cursor: pointer;
        color: var(--ink-dim);
        font-size: 13.5px;
        user-select: none;
      }
      .month summary:hover {
        color: var(--ink);
      }
      .month ul.hl {
        margin: 12px 0 0;
        padding-left: 0;
        list-style: none;
      }
      .month ul.hl li {
        padding: 5px 0 5px 22px;
        position: relative;
        font-size: 13.5px;
        border-bottom: 1px dashed var(--line);
      }
      .month ul.hl li::before {
        content: "▸";
        position: absolute;
        left: 0;
        color: var(--crow);
      }

      table {
        width: 100%;
        border-collapse: collapse;
        font-size: 13.5px;
      }
      thead th {
        text-align: left;
        color: var(--ink-dim);
        font-weight: 600;
        padding: 10px 10px;
        border-bottom: 1px solid var(--line);
        font-size: 12.5px;
      }
      tbody td {
        padding: 11px 10px;
        border-bottom: 1px solid var(--line);
        vertical-align: middle;
      }
      tbody tr:hover {
        background: var(--bg-card2);
      }
      td.wk {
        font-weight: 700;
        color: var(--crow);
        white-space: nowrap;
      }
      td.rng {
        color: var(--ink-dim);
        font-variant-numeric: tabular-nums;
        white-space: nowrap;
      }
      td.note {
        color: var(--ink-dim);
        font-size: 12.5px;
      }
      .bartd {
        width: 180px;
      }
      .minibar {
        height: 9px;
        border-radius: 5px;
        background: var(--feat);
        display: inline-block;
        vertical-align: middle;
      }
      .num-cell {
        font-variant-numeric: tabular-nums;
        text-align: right;
        font-weight: 600;
      }
      .badge-m {
        display: inline-block;
        font-size: 10.5px;
        padding: 1px 7px;
        border-radius: 20px;
        background: var(--bg-card2);
        color: var(--ink-dim);
        border: 1px solid var(--line);
      }
      .hiatus-row td {
        background: repeating-linear-gradient(
          45deg,
          transparent,
          transparent 8px,
          rgba(255, 255, 255, 0.02) 8px,
          rgba(255, 255, 255, 0.02) 16px
        );
        color: var(--ink-dim);
        font-style: italic;
        text-align: center;
        font-size: 12.5px;
      }

      .foot {
        margin-top: 70px;
        padding-top: 22px;
        border-top: 1px solid var(--line);
        color: var(--ink-dim);
        font-size: 12.5px;
        text-align: center;
      }
      .tag-pill {
        display: inline-block;
        background: rgba(52, 211, 153, 0.14);
        color: var(--refactor);
        border: 1px solid rgba(52, 211, 153, 0.4);
        border-radius: 20px;
        padding: 4px 14px;
        font-weight: 700;
        font-size: 13px;
      }

      @media (max-width: 720px) {
        .stats {
          grid-template-columns: repeat(2, 1fr);
        }
        header.hero h1 {
          font-size: 30px;
        }
        .bartd {
          display: none;
        }
        td.note {
          display: none;
        }
      }
    </style>
  </head>
  <body>
    <div class="topbar">
      <a class="back" href="/karasu/retrospective/" data-i="backHome">← karasu docs</a>
      <span class="langtoggle">
        <button data-lang="en" onclick="setLang('en')">English</button>
        <button data-lang="ja" onclick="setLang('ja')">日本語</button>
      </span>
    </div>

    <header class="hero">
      <div class="crow-mark">🐦‍⬛</div>
      <h1><span class="jp">karasu</span>（鴉）1.0</h1>
      <p class="sub" data-i="sub"></p>
      <p class="period"><b id="d0"></b> → <b id="d1"></b> ・ <b id="dweeks"></b></p>
      <div class="snapshot" data-i="snapshot"></div>
    </header>

    <div class="wrap">
      <div class="stats" id="stats"></div>

      <h2 class="section" data-i="s1title"></h2>
      <p class="section-note" data-i="s1note"></p>
      <div class="card">
        <h3 data-i="c1title"></h3>
        <p class="hint" data-i="c1hint"></p>
        <div id="weeklyChart"></div>
        <div class="legend">
          <span><i style="background: var(--feat)"></i><span data-i="lgCommits"></span></span>
          <span><i style="background: var(--adr)"></i><span data-i="lgAdr"></span></span>
          <span><i style="background: var(--tpl)"></i><span data-i="lgTpl"></span></span>
        </div>
      </div>
      <div class="card">
        <h3 data-i="c2title"></h3>
        <p class="hint" data-i="c2hint"></p>
        <div id="cumChart"></div>
        <div class="legend">
          <span><i style="background: var(--adr)"></i><span data-i="lgAdrCum"></span></span>
          <span><i style="background: var(--tpl)"></i><span data-i="lgTplCum"></span></span>
        </div>
      </div>

      <h2 class="section" data-i="s2title"></h2>
      <p class="section-note" data-i="s2note"></p>
      <div id="months"></div>

      <h2 class="section" data-i="s3title"></h2>
      <p class="section-note" data-i="s3note"></p>
      <div class="card" style="padding: 8px 8px 4px">
        <div style="overflow-x: auto">
          <table id="weekTable">
            <thead>
              <tr>
                <th data-i="thWeek"></th>
                <th data-i="thPeriod"></th>
                <th data-i="thMonth"></th>
                <th class="num-cell">commit</th>
                <th class="bartd">　</th>
                <th class="num-cell">ADR</th>
                <th class="num-cell">TPL</th>
                <th class="note" data-i="thHighlight"></th>
              </tr>
            </thead>
            <tbody></tbody>
          </table>
        </div>
      </div>

      <h2 class="section" data-i="s4title"></h2>
      <div class="card">
        <p style="margin: 0 0 14px"><span class="tag-pill">🏁 krs-spec-v1.0</span></p>
        <p style="margin: 0; font-size: 14.5px" data-i="s4body"></p>
      </div>

      <div class="foot" data-i="foot"></div>
    </div>

    <script is:inline>
      /* ===== shared numeric dataset (language-independent) ===== */
      const META = {
        firstCommit: "2026-03-13",
        lastCommit: "2026-06-25",
