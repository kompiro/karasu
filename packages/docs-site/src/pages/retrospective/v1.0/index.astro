          lgTpl: "TPLs (test perspectives)",
          c2title: "Cumulative knowledge assets — ADRs and TPLs",
          c2hint:
            "How design decisions (ADRs) and test perspectives (TPLs) accumulated over time. TPLs take off once the practice began in May (ADR-20260509-04).",
          lgAdrCum: "ADRs (cumulative)",
          lgTplCum: "TPLs (cumulative)",
          s2title: "② Monthly summary",
          s2note:
            "Each month's theme, volume, commit-type breakdown, and key design decisions (click to expand).",
          s3title: "③ Weekly summary",
